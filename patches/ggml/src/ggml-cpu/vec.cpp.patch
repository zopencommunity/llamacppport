+        const float32x4_t vneg1 = vec_splats(-1.0f);
+        for (; j + 3 < n; j += 4) {
+            vec_xst(vec_mul(vec_xl(0, x + j), vneg1), 0, tmp + j);
+        }
+#endif
+        for (; j < n; j++) {
+            tmp[j] = -x[j];
+        }
