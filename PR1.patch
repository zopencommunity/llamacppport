index 34184ed..4005c60 100644
--- a/ggml/src/ggml-cpu/arch/s390/quants.c
+++ b/ggml/src/ggml-cpu/arch/s390/quants.c
@@ -144,6 +144,66 @@ void quantize_row_q8_1(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, i
 }
 
 
+void quantize_row_q8_K(const float * GGML_RESTRICT x, void * GGML_RESTRICT vy, int64_t k) {
+    assert(k % QK_K == 0);
+    const int64_t nb = k / QK_K;
+
+    block_q8_K * GGML_RESTRICT y = vy;
+
+#if defined(__VXE__) || defined(__VXE2__) || defined(__MVS__)
+    for (int64_t i = 0; i < nb; i++) {
+        const float * src = x + i * QK_K;
+
+        // Find max and amax (scalar, matches reference behavior exactly)
+        float max = 0;
+        float amax = 0;
+        for (int j = 0; j < QK_K; ++j) {
+            float ax = fabsf(src[j]);
+            if (ax > amax) {
+                amax = ax; max = src[j];
+            }
+        }
+
+        if (!amax) {
+            y[i].d = 0;
+            memset(y[i].qs, 0, QK_K);
+            memset(y[i].bsums, 0, QK_K/16 * sizeof(int16_t));
+            continue;
+        }
+
+        const float iscale = -127.f / max;
+        y[i].d = 1.f / iscale;
+
+        const float32x4_t vscale = vec_splats(iscale);
+
+        // Quantize in groups of 16 and compute block sums
+        // QK_K/16 = 16 groups, each group = 4 vectors of 4 floats
+        for (int g = 0; g < QK_K/16; g++) {
+            int32x4_t acc = vec_splats(0);
+
+            for (int j = 0; j < 4; j++) {
+                const float32x4_t v = vec_mul(vec_xl(0, src + g*16 + 4*j), vscale);
+                const int32x4_t vi = vec_signed(__builtin_s390_vfisb(v, 4, 1));
+
+                y[i].qs[g*16 + 4*j + 0] = MIN(127, vec_extract(vi, 0));
+                y[i].qs[g*16 + 4*j + 1] = MIN(127, vec_extract(vi, 1));
+                y[i].qs[g*16 + 4*j + 2] = MIN(127, vec_extract(vi, 2));
+                y[i].qs[g*16 + 4*j + 3] = MIN(127, vec_extract(vi, 3));
+
+                acc = vec_add(acc, vi);
+            }
+
+            y[i].bsums[g] = vec_extract(acc, 0) + vec_extract(acc, 1) +
+                            vec_extract(acc, 2) + vec_extract(acc, 3);
+        }
+    }
+#else
+    GGML_UNUSED(nb);
+    // scalar
+    quantize_row_q8_K_ref(x, y, k);
+#endif
+}
