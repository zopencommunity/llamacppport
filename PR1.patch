+    const uint32x4_t v_23 = vec_splats((uint32_t)23);
+    const uint32x4_t e = vec_sl(vxe_reinterpret_u32_f32(z), v_23);
+    const float32x4_t k = vxe_reinterpret_f32_u32(vec_add(e, vxe_reinterpret_u32_f32(vec_splats(1.0f))));
+
+    const float32x4_t abs_n = vec_abs(n);
+    const uint32x4_t c = (uint32x4_t)vec_cmpgt(abs_n, vec_splats(126.0f));
+
+    const float32x4_t u = vec_mul(b, b);
+    // Polynomial: j = 0x1.ffffecp-1 * b + (0x1.fffdb6p-2 + 0x1.555e66p-3*b + (0x1.573e2ep-5 + 0x1.0e4020p-7*b)*u)*u
+    const float32x4_t j = vec_add(
+        vec_mul(vec_splats(0x1.ffffecp-1f), b),
+        vec_mul(vec_add(
+            vec_add(vec_splats(0x1.fffdb6p-2f), vec_mul(vec_splats(0x1.555e66p-3f), b)),
+            vec_mul(vec_add(vec_splats(0x1.573e2ep-5f), vec_mul(vec_splats(0x1.0e4020p-7f), b)), u)
+        ), u));
+
+    // Fast path: if all |n| <= 126
+    if (!(c[0] | c[1] | c[2] | c[3])) {
+        return vec_add(k, vec_mul(j, k));  // k + j*k = k*(1+j)
+    }
+
+    // Slow path for overflow/underflow
+    const uint32x4_t neg_mask = (uint32x4_t)vec_cmple(n, vec_splats(0.0f));
+    const uint32x4_t v_82 = vec_splats((uint32_t)0x82000000u);
+    const uint32x4_t v_7f = vec_splats((uint32_t)0x7f000000u);
+    const uint32x4_t d = vec_and(neg_mask, v_82);
+    const float32x4_t s1 = vxe_reinterpret_f32_u32(vec_add(d, v_7f));
+    const float32x4_t s2 = vxe_reinterpret_f32_u32(vec_sub(e, d));
+
+    const uint32x4_t d2 = (uint32x4_t)vec_cmpgt(abs_n, vec_splats(192.0f));
+    // result = d2 ? s1*s1 : (c ? (s2 + s2*j)*s1 : k + k*j)
+    const float32x4_t overflow   = vec_mul(s1, s1);
+    const float32x4_t big_result = vec_mul(vec_add(s2, vec_mul(s2, j)), s1);
+    const float32x4_t normal     = vec_add(k, vec_mul(k, j));
+
+    // Select: c ? big_result : normal
+    const float32x4_t r1 = vec_sel(normal, big_result, c);
+    // Select: d2 ? overflow : r1
+    return vec_sel(r1, overflow, d2);
+}
+
+// computes silu x/(1+exp(-x)) in single precision vector
+inline static float32x4_t ggml_v_silu(float32x4_t x) {
+    const float32x4_t one = vec_splats(1.0f);
+    const float32x4_t zero = vec_splats(0.0f);
+    const float32x4_t neg_x = vec_sub(zero, x);
+    const float32x4_t exp_neg_x = ggml_v_expf(neg_x);
+    const float32x4_t one_plus_exp_neg_x = vec_add(one, exp_neg_x);
+    return vec_div(x, one_plus_exp_neg_x);
+}
